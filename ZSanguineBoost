-- FPS Drop Lag, only when Sanguine Z is actually played
local lagBusy = false
local function dropFPS()
    if lagBusy then return end
    lagBusy = true
    local stop = tick() + LAG_DURATION
    local interval = 1 / DROP_TO_FPS
    local con
    con = rs.RenderStepped:Connect(function()
        if tick() > stop then
            if con then con:Disconnect() end
            return
        end
        local now = tick()
        while tick() - now < interval do end
    end)
    task.wait(0.10)
    lagBusy = false
end

-- Detect Sanguine Foul Strike activation by AnimationId playing
local function connectSanguineWatcher()
    local char = lp.Character or lp.CharacterAdded:Wait()
    local hum = char:WaitForChild("Humanoid")
    -- Disconnect old connections if character respawns
    if hum:FindFirstChild("__CUPIDS_SANGUINE") then
        hum:FindFirstChild("__CUPIDS_SANGUINE"):Destroy()
    end
    local flag = Instance.new("BoolValue")
    flag.Name = "__CUPIDS_SANGUINE"
    flag.Parent = hum
    hum.AnimationPlayed:Connect(function(anim)
        if tostring(anim.Animation.AnimationId):find(SANGUINE_ANIMATION_ID) then
            dropFPS()
        end
    end)
end

lp.CharacterAdded:Connect(function()
    task.wait(1)
    connectSanguineWatcher()
end)
if lp.Character then connectSanguineWatcher() end

-- [Optional] Still allow Z key or GUI press as manual trigger (for backup & fun)
uis.InputBegan:Connect(function(i, gpe)
    if gpe then return end
    if i.KeyCode == Enum.KeyCode.Z then
        dropFPS()
    end
end)
zBtn.MouseButton1Click:Connect(dropFPS)

